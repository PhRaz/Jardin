# Config HTTPS avec domaine réel.
# Remplacer TON_DOMAINE.fr par ton domaine, puis dans docker-compose.prod.yml
# remettre ce fichier à la place de Caddyfile.

caljar.fr {
	root * /var/www/html/public

	encode gzip

	@notStatic {
		not file
	}
	rewrite @notStatic /index.php

	php_fastcgi php:9000

	file_server
}
