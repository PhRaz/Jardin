<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calendrier des plantes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        td.details { font-size: 0.9em; color: #666; }

        @media (max-width: 767px) {
            .table-operations thead { display: none; }
            .table-operations tbody tr {
                display: flex;
                flex-wrap: wrap;
                border-bottom: 1px solid #dee2e6;
                padding: 0.5rem 0;
            }
            .table-operations tbody tr td {
                border: none;
                padding: 0.15rem 0.5rem;
            }
            .table-operations tbody tr td:nth-child(1) { font-weight: bold; }
            .table-operations tbody tr td:nth-child(2) { margin-left: auto; }
            .table-operations tbody tr td:nth-child(3) { width: 100%; order: 3; }
        }
    </style>
</head>
<body>

<nav class="navbar navbar-dark bg-success mb-4">
    <div class="container">
        <a class="navbar-brand mb-0 h1" href="{{ path('app_index') }}" style="text-decoration: none;">Calendrier des plantes</a>
    </div>
</nav>

<div class="container">
    {% block body %}{% endblock %}
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
