{% extends 'base.html.twig' %}

{% block body %}
<div class="d-flex flex-column gap-2 mb-3">
    <div class="d-flex align-items-center gap-2">
        <label for="view" class="form-label fw-bold mb-0 text-nowrap">Vue :</label>
        <select id="view" class="form-select" onchange="if(this.value==='month') window.location='{{ path('app_mois', {mois: moisCourant}) }}'">
            <option value="month">Par mois</option>
            <option value="plant" selected>Par plante</option>
        </select>
    </div>
    <div class="d-flex align-items-center gap-2">
        <label for="plant" class="form-label fw-bold mb-0 text-nowrap">Plante :</label>
        <select id="plant" class="form-select" onchange="window.location='/plante/'+encodeURIComponent(this.value)">
            {% for type, plantesDuType in plantesParType %}
                <optgroup label="{{ type|capitalize }}">
                    {% for p in plantesDuType %}
                        <option value="{{ p.nom }}"{% if p.nom == plante.nom %} selected{% endif %}>{{ p.nom }}</option>
                    {% endfor %}
                </optgroup>
            {% endfor %}
        </select>
    </div>
</div>

<h2>Opérations pour {{ plante.nom }}</h2>

<table class="table table-striped table-hover table-operations">
    <thead>
        <tr>
            <th>Mois</th>
            <th>Opération</th>
            <th>Détails</th>
        </tr>
    </thead>
    <tbody>
        {% for op in plante.entretien|sort((a, b) => a.mois <=> b.mois) %}
            <tr>
                <td><a class="btn-link-nav" href="{{ path('app_mois', {mois: op.mois}) }}">{{ moisLabels[op.mois] }}</a></td>
                <td>{{ op.operation }}</td>
                <td class="details">
                    <span class="details-texte" data-details="{{ op.details }}">{{ op.details|nl2br }}</span>
                    {% if is_granted('ROLE_ADMIN') %}
                    <button class="btn btn-sm btn-link p-0 ms-2 text-secondary"
                            data-action="editer-details"
                            data-id="{{ op.id }}"
                            title="Modifier">✏️</button>
                    {% endif %}
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>

<div id="details-section" class="mt-4" data-nom="{{ plante.nom|e('html_attr') }}">
    <div class="text-center my-3">
        <div class="spinner-border text-success" role="status">
            <span class="visually-hidden">Chargement...</span>
        </div>
        <p class="mt-2 text-muted">Chargement des informations botaniques...</p>
    </div>
</div>

{% if plante.photos|length > 0 or is_granted('ROLE_ADMIN') %}
<div class="mt-4">
    <h5>Photos</h5>

    {% if plante.photos|length > 0 %}
    <div id="photos-grid" class="row g-3 mb-3">
        {% for photo in plante.photos %}
        <div class="col-6 col-md-4" id="photo-{{ photo.id }}">
            <div class="position-relative">
                <img src="{{ photo.chemin }}" class="img-fluid rounded shadow-sm w-100" style="object-fit:cover;max-height:200px" alt="Photo du {{ photo.priseLe|date('d/m/Y') }}">
                {% if is_granted('ROLE_ADMIN') %}
                <button class="btn btn-danger btn-sm position-absolute top-0 end-0 m-1"
                        data-action="supprimer-photo"
                        data-id="{{ photo.id }}"
                        data-nom="{{ plante.nom|e('html_attr') }}"
                        title="Supprimer cette photo">🗑</button>
                {% endif %}
            </div>
            <div class="text-center text-muted small mt-1">{{ photo.priseLe|date('d/m/Y') }}</div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

    {% if is_granted('ROLE_ADMIN') %}
    <div id="camera-section"
         data-nom="{{ plante.nom|e('html_attr') }}"
         data-csrf="{{ csrf_token('upload-photo') }}">
        <button class="btn btn-outline-success btn-sm" id="btn-ouvrir-camera">📷 Ajouter une photo</button>
        <div id="camera-ui" class="mt-3 d-none">
            <video id="camera-video" autoplay playsinline class="img-fluid rounded" style="max-height:300px"></video>
            <canvas id="camera-canvas" class="d-none"></canvas>
            <img id="camera-preview" class="img-fluid rounded d-none" style="max-height:300px" alt="Aperçu">
            <div class="mt-2 d-flex gap-2 flex-wrap">
                <button class="btn btn-success btn-sm" id="btn-capturer">📸 Capturer</button>
                <button class="btn btn-primary btn-sm d-none" id="btn-sauvegarder-photo">💾 Enregistrer</button>
                <button class="btn btn-outline-secondary btn-sm d-none" id="btn-reprendre">↩ Reprendre</button>
                <button class="btn btn-secondary btn-sm" id="btn-annuler-camera">Annuler</button>
            </div>
            <div id="photo-error" class="alert alert-danger mt-2 d-none"></div>
        </div>
    </div>
    {% endif %}
</div>
{% endif %}

{% endblock %}
