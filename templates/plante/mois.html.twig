{% extends 'base.html.twig' %}

{% block body %}
<input type="hidden" id="mois-courant" value="{{ moisCourant }}">
<div id="swipe-hint-prev" class="swipe-hint" style="left:6px">‹</div>
<div id="swipe-hint-next" class="swipe-hint" style="right:6px">›</div>

<div class="d-flex align-items-center gap-3 mb-3">
    <div class="d-flex flex-column gap-2">
        <div class="d-flex align-items-center gap-2">
            <label for="view" class="form-label fw-bold mb-0 text-nowrap">Vue :</label>
            <select id="view" class="form-select" onchange="if(this.value==='plant') window.location='{{ path('app_plante', {nom: premierePlante}) }}'">
                <option value="month" selected>Par mois</option>
                <option value="plant">Par plante</option>
            </select>
        </div>
        <div class="d-flex align-items-center gap-2">
            <label for="month" class="form-label fw-bold mb-0 text-nowrap">Mois :</label>
            <select id="month" class="form-select" onchange="window.location='/mois/'+this.value">
                {% for i in 1..12 %}
                    <option value="{{ i }}"{% if i == moisCourant %} selected{% endif %}>{{ moisLabels[i] }}</option>
                {% endfor %}
            </select>
        </div>
    </div>
    <div class="ms-auto flex-shrink-0 d-flex flex-column gap-2">
        <button class="btn btn-outline-success" data-bs-toggle="modal" data-bs-target="#calendrierModal">
            📅 Calendrier
        </button>
        <a href="{{ path('app_potager') }}" class="btn btn-outline-success">
            🌱 Potager
        </a>
    </div>
</div>

{# Modal Calendrier #}
<div class="modal fade" id="calendrierModal" tabindex="-1" aria-labelledby="calendrierModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="calendrierModalLabel">Générer un calendrier</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="cal-type" class="form-label fw-bold">Type de plante</label>
                    <select id="cal-type" class="form-select">
                        {% for type in typesPlantes %}
                            <option value="{{ type }}">{{ type|capitalize }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="mb-3">
                    <label for="cal-format" class="form-label fw-bold">Format</label>
                    <select id="cal-format" class="form-select">
                        <option value="a4">A4 portrait</option>
                        <option value="a3">A3 portrait</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" onclick="ouvrirCalendrier('apercu')">🔍 Aperçu</button>
                <button class="btn btn-success" onclick="ouvrirCalendrier('pdf')">⬇ Télécharger PDF</button>
            </div>
        </div>
    </div>
</div>
<script>
function ouvrirCalendrier(mode) {
    var type = document.getElementById('cal-type').value;
    var format = document.getElementById('cal-format').value;
    var url = '/calendrier/' + mode + '?type=' + encodeURIComponent(type) + '&format=' + encodeURIComponent(format);
    if (mode === 'apercu') {
        window.open(url, '_blank');
    } else {
        window.location = url;
    }
}
</script>

<h2>Opérations pour {{ moisLabels[moisCourant] }}</h2>

{% for type, operations in operationsParType %}
    <h5 class="mt-3">{{ type|capitalize }}</h5>
    <table class="table table-striped table-hover table-operations" style="table-layout:fixed">
        <colgroup>
            <col style="width:18%">
            <col style="width:16%">
            <col>
            <col style="width:90px">
        </colgroup>
        <thead>
            <tr>
                <th>Plante</th>
                <th>Opération</th>
                <th>Détails</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for op in operations %}
                <tr>
                    <td><a class="btn-link-nav" href="{{ path('app_plante', {nom: op.nom}) }}">{{ op.nom }}</a></td>
                    <td>{{ op.operation }}</td>
                    <td class="details">
                        <span class="details-texte" data-details="{{ op.details }}">{{ op.details|nl2br }}</span>
                        {% if is_granted('ROLE_ADMIN') %}
                        <button class="btn btn-sm btn-link p-0 ms-2 text-secondary"
                                data-action="editer-details"
                                data-id="{{ op.id }}"
                                title="Modifier">✏️</button>
                        {% endif %}
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-success"
                                data-action="ouvrir-details"
                                data-nom="{{ op.nom|e('html_attr') }}">
                            Détails
                        </button>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% else %}
    <p class="text-muted">Aucune opération ce mois-ci.</p>
{% endfor %}

{# Modale Bootstrap #}
<div class="modal fade" id="plantModal" tabindex="-1" aria-labelledby="plantModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="plantModalLabel"></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body" id="plantModalBody"></div>
        </div>
    </div>
</div>

{% endblock %}
