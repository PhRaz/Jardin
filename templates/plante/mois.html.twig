{% extends 'base.html.twig' %}

{% block body %}
<div class="row mb-3">
    <div class="col-auto">
        <label for="view" class="form-label fw-bold">Vue :</label>
        <select id="view" class="form-select" onchange="if(this.value==='plant') window.location='{{ path('app_plante', {nom: premierePlante}) }}'">
            <option value="month" selected>Par mois</option>
            <option value="plant">Par plante</option>
        </select>
    </div>
    <div class="col-auto">
        <label for="month" class="form-label fw-bold">Mois :</label>
        <select id="month" class="form-select" onchange="window.location='/mois/'+this.value">
            {% for i in 1..12 %}
                <option value="{{ i }}"{% if i == moisCourant %} selected{% endif %}>{{ moisLabels[i] }}</option>
            {% endfor %}
        </select>
    </div>
</div>

<h2>Opérations pour {{ moisLabels[moisCourant] }}</h2>

{% for type, operations in operationsParType %}
    <h5 class="mt-3">{{ type|capitalize }}</h5>
    <table class="table table-striped table-hover table-operations" style="table-layout:fixed">
        <colgroup>
            <col style="width:18%">
            <col style="width:16%">
            <col>
            <col style="width:90px">
        </colgroup>
        <thead>
            <tr>
                <th>Plante</th>
                <th>Opération</th>
                <th>Détails</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for op in operations %}
                <tr>
                    <td>{{ op.nom }}</td>
                    <td>{{ op.operation }}</td>
                    <td class="details">{{ op.details }}</td>
                    <td>
                        <button class="btn btn-sm btn-outline-success"
                                data-action="ouvrir-details"
                                data-nom="{{ op.nom|e('html_attr') }}">
                            Détails
                        </button>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% else %}
    <p class="text-muted">Aucune opération ce mois-ci.</p>
{% endfor %}

{# Modale Bootstrap #}
<div class="modal fade" id="plantModal" tabindex="-1" aria-labelledby="plantModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="plantModalLabel"></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body" id="plantModalBody"></div>
        </div>
    </div>
</div>

{% endblock %}
