# Copier ce fichier en .env.local sur le serveur et remplir les valeurs

# Symfony
APP_ENV=prod
APP_SECRET=                     # générer avec : openssl rand -hex 32
APP_SHARE_DIR=var/share

# MongoDB — doit correspondre aux valeurs ci-dessous
MONGODB_URI=mongodb://jardin:CHANGE_PASSWORD@mongo:27017/?authSource=admin
MONGODB_DB=jardin

# MongoDB Docker (lu par docker-compose.prod.yml)
MONGO_USER=jardin
MONGO_PASSWORD=CHANGE_PASSWORD  # choisir un mot de passe fort

